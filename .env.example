# Copy to .env and fill in. .env is gitignored.

# The Odds API key (free tier: https://the-odds-api.com). Optional —
# without it the dashboard board uses bundled sample data.
ODDS_API_KEY=

# Optional: use Postgres instead of the default SQLite file.
# DATABASE_URL=postgresql+psycopg2://courtedge:courtedge@localhost:5432/courtedge

# Optional overrides
# SEASONS=2019-20,2020-21,2021-22,2022-23,2023-24
# ROLL_WINDOW=10
# KELLY_FRACTION=0.25
